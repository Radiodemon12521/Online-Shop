@page "/products"
@using MudBlazor
@using Shop.Common
@using Shop.Entities

@inject IDialogService DialogService
@inject ApiClient ApiClient

<h3>Products</h3>

<MudFab Color="Color.Primary"
        StartIcon="@Icons.Material.Filled.Add"
        Size="Size.Small"
        OnClick="OpenAddDialog" />

<MudGrid Class="mt-4">
    @foreach (var product in ProductsList)
    {
        <MudItem xs="12" sm="6" md="3">
            <MudCard Style="cursor:pointer"
                     onclick="@(() => OpenDialog(product))">

                <MudCardMedia Image="@product.ImageSource"
                              Height="150" />

                <MudCardContent>
                    <MudText Typo="Typo.h6">@product.Name</MudText>
                    <MudText Typo="Typo.body2">@product.Price €</MudText>
                </MudCardContent>

            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {

    public List<Product> ProductsList { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        ProductsList = await ApiClient.GetAllProducts();
    }

    async Task OpenDialog(Product product)
    {
        var parameters = new DialogParameters
        {
            { "Product", product },
            { "IsCreate", false }
        };

        var dialog = await DialogService.ShowAsync<DialogProduct>("Товар", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadData();
    }

    async Task OpenAddDialog()
    {
        var parameters = new DialogParameters
        {
            { "Product", new Product { Id = Guid.NewGuid() } },
            { "IsCreate", true }
        };

        var dialog = await DialogService.ShowAsync<DialogProduct>("Новый товар", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
            await LoadData();
    }
}