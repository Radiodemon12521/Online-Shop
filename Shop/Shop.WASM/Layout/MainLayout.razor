
@using MudBlazor
@using Shop.Common
@using Shop.Entities
@using ShopWASM
@inject ApiClient ApiClient
@inherits LayoutComponentBase
@inject CartService CartService
@inject NavigationManager Nav
@implements IDisposable


<MudThemeProvider />
<MudPopoverProvider />


<MudDialogProvider />


<MudSnackbarProvider />

<MudLayout>
  
<MudDrawer @bind-Open="@_drawerOpen"
           Anchor="Anchor.Left"
           Elevation="2"
           Variant="@DrawerVariant.Temporary"
          style="background: #1a0505;">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6" Style="color: #f0e6d3; letter-spacing: 0.1em;">Каталог</MudText>
    </MudDrawerHeader>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Error" />
    }
    else
    {
        <MudTreeView T="object"
                     Items="@TreeItems"
                     ServerData="LoadServerData"
                     CanHover="true"
                     CanActivate="true"
                     Style="background: transparent; color: #f0e6d3;">
            <ItemTemplate Context="item">
                <MudTreeViewItem Value="@item.Value"
                                 Text="@item.Text"
                                 Items="@item.Children"
                                 Expandable="@item.Expandable"
                                 OnClick="@(() => SelectCategory(item))"
                                 Style="color: #f0e6d3;" >
                                 <BodyContent>
                            @{
                                string name = "abr";
                                if (@context.Value is Product product) name = product.Name;
                                if (@context.Value is Category category) name = category.Name;
                                var categorys = context.Value as Category;
                            }
                        <MudButton OnClick="()=>ChangeCategory(categorys)">@name</MudButton> 
                                   
                                 </BodyContent>
                             </MudTreeViewItem>
                                 

            </ItemTemplate>
        </MudTreeView>
    }
</MudDrawer>
<div class="shop">
    <nav class="nav">

        <div class="logo">MAISON<span>.</span></div>

        
        <div class="buttons">
            <button class="item">Всё</button>
            <button class="item">Тренд</button>
            <button class="item">Акции</button>
            <NavLink href="/admin"  class="btn btn-primary">
                Админ панель
            </NavLink>
                <NavLink href="/register" class="item">
                    Регистрация
                </NavLink>
        </div>


            <button class="cart-btn" @onclick='() => Nav.NavigateTo("/cart")'>
                🛒 <span class="cart-count">@CartService.TotalCount</span>
            </button>
    </nav>
    <div class="catalog">


        <div class="hero-text">

            <div class="catalog-badge">
                限定コレクション
                Limited Collection
            </div>

            <h1 class="shop-title">
                静かな贅沢
                Quiet Luxury
            </h1>

            <p class="hero-sub">Здесь только настоящее</p>

            <button class="hero-cta" @onclick="OpenDrawer">Смотреть каталог →</button>

        </div>
    </div>
  
    <div class="section-header">
        <div class="section-title">Каталог</div>

        <div class="section-link" id="itemCount">12 товаров</div>
    </div>
            <div class="filter-bar">
                <button class="filter-chip @(CurrentSort == "price-asc" ? "active" : "")" @onclick='() => SetSort("price-asc")'>Дешевле</button>
                <button class="filter-chip @(CurrentSort == "price-desc" ? "active" : "")" @onclick='() => SetSort("price-desc")'>Дороже</button>
            </div>
    <CascadingValue Value="CurrentCategory">
            <CascadingValue Value="CurrentSort" Name="SortOrder">
                @Body
            </CascadingValue>
    </CascadingValue>
</div>
</MudLayout>
@code {
    public string CurrentSort { get; set; } = "default";

    private bool _drawerOpen;
    public Category CurrentCategory{ get; set; }
    void SetSort(string sort)
    {
        CurrentSort = sort;
        StateHasChanged();
    }
    public void  ChangeCategory(Category category)
    {
        if (category is not null)
        {
            CurrentCategory = category;
        }
    }
    protected override void OnInitialized()
    {
        CartService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        CartService.OnChange -= StateHasChanged;
    }
    private async Task OpenDrawer()
    {
        _drawerOpen = true;
        if (!TreeItems.Any())
        {
            _loading = true;
            await LoadData();
            _loading = false;
        }
    }

    private bool _loading;
    public List<TreeItemData<object>> TreeItems { get; set; } = new();

    private async Task LoadData()
    {
        var categories = await ApiClient.GetChildren(null);
        TreeItems = categories
            .Select(c => new TreeItemData<object>
            {
                Text = c.Name,
                Value = (object)c,
                Expandable = c.Children?.Any() == true || c.Products?.Any() == true
            })
            .ToList();
    }

    public async Task<IReadOnlyCollection<TreeItemData<object>>> LoadServerData(object parentValue)
    {
        var items = new List<TreeItemData<object>>();
        if (parentValue is not Category category)
            return items;

        var children = await ApiClient.GetChildren(category.Id);
        foreach (var child in children)
        {
            items.Add(new TreeItemData<object>
            {
                Text = child.Name,
                Value = (object)child,
                Expandable = child.Children?.Any() == true || child.Products?.Any() == true
            });
        }

        if (category.Products != null)
        {
            items.AddRange(category.Products.Select(p => new TreeItemData<object>
            {
                Text = p.Name,
                Value = (object)p,
                Expandable = false
            }));
        }

        return items;
    }

    private void SelectCategory(TreeItemData<object> context)
    {
        _drawerOpen = false;
    }
}
