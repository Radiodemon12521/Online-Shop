@page "/"
@using MudBlazor
@using Shop.Common
@using Shop.Entities
@inject ApiClient ApiClient

<h3>Products</h3>

<MudGrid Class="mt-4">
    @foreach (var product in ProductsList)
    {
        <MudItem xs="12" sm="6" md="3">
            <MudCard>
                <MudCardMedia Image="@product.ImageSource" Height="150" />
                <MudCardContent>
                    <MudText Typo="Typo.h6">@product.Name</MudText>
                    <MudText Typo="Typo.body2">@product.Price €</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

    @code {
    public List<Product> ProductsList { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {

        var httpResponseMessage=await ApiClient.TryGetAllProducts();
        if (httpResponseMessage.IsSuccessStatusCode)
        {
            ProductsList = await httpResponseMessage.Content.ReadFromJsonAsync<List<Product>>();
        }
    }
}