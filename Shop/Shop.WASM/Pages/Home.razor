@page "/"
@using MudBlazor
@using Shop.Common
@using Shop.Entities
@using ShopWASM
@inject ApiClient ApiClient
@inject CartService CartService

<div class="products-grid">
    @foreach (var product in ProductsList)
    {
        <div class="product-card">
            <div class="product-img-wrap">
                <img src="@product.ImageSource" alt="@product.Name" class="product-img" />
            </div>
            <div class="product-info">
                <div class="product-meta">
                    <span class="product-name">@product.Name</span>
                    <span class="product-price">@product.Price €</span>
                </div>
                <button class="add-to-cart-btn @(AddedProducts.Contains(product.Id) ? "added" : "")"
                        @onclick="() => AddToCart(product)">
                    <span class="btn-icon">@(AddedProducts.Contains(product.Id) ? "✓" : "+")</span>
                </button>
            </div>
        </div>
    }
</div>

<style>
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1.5rem;
        padding: 2rem;
        background: #1a0505;
    }

    .product-card {
        background: #2a0a0a;
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 4px;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.2s ease, border-color 0.2s ease;
    }

        .product-card:hover {
            transform: translateY(-4px);
            border-color: rgba(180, 60, 60, 0.5);
        }

    .product-img-wrap {
        width: 100%;
        height: 220px;
        overflow: hidden;
    }

    .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .product-card:hover .product-img {
        transform: scale(1.05);
    }

    .product-info {
        padding: 1rem 1.2rem;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .product-meta {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .product-name {
        color: #f0e6d3;
        font-size: 1rem;
        font-weight: 500;
        letter-spacing: 0.02em;
    }

    .product-price {
        color: #a06060;
        font-size: 0.9rem;
    }


    .add-to-cart-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 2px solid rgba(180, 60, 60, 0.6);
        background: transparent;
        color: #a06060;
        font-size: 1.4rem;
        line-height: 1;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
    }

        .add-to-cart-btn:hover {
            background: rgba(180, 60, 60, 0.2);
            border-color: #b43c3c;
            color: #f0e6d3;
            transform: scale(1.1);
        }

        .add-to-cart-btn:active {
            transform: scale(0.95);
        }

        .add-to-cart-btn.added {
            background: rgba(180, 60, 60, 0.25);
            border-color: #b43c3c;
            color: #f0e6d3;
        }

    .btn-icon {
        pointer-events: none;
        font-style: normal;
    }
</style>

@code {
    [CascadingParameter]
    public Category CurrentCategory{ get; set; }

    public List<Product> ProductsList { get; set; } = new();

    [CascadingParameter(Name = "SortOrder")]
    public string SortOrder { get; set; } = "default";

    private HashSet<Guid> AddedProducts { get; set; } = new();
    private string _lastSort;
  List<Product> ApplySort(List<Product> products)
{
    switch (SortOrder)
    {
        case "price-asc":
            return products.OrderBy(p => p.Price).ToList();

        case "price-desc":
            return products.OrderByDescending(p => p.Price).ToList();

        default:
            return products;
    }
}
    protected override async Task OnParametersSetAsync()
    {
        if (_lastSort != SortOrder)
        {
            _lastSort = SortOrder;
            ProductsList = ApplySort(ProductsList); 
            return;
        }
        await LoadData();
    }
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        HttpResponseMessage httpResponseMessage;
        if (CurrentCategory is null)
            httpResponseMessage = await ApiClient.TryGetAllProducts();
        else
            httpResponseMessage = await ApiClient.TryByCategory(CurrentCategory);

        if (httpResponseMessage.IsSuccessStatusCode)
        {
            var products = await httpResponseMessage.Content.ReadFromJsonAsync<List<Product>>();
            ProductsList = ApplySort(products);
        }
    }
    void AddToCart(Product product)
    {
        CartService.Add(product);
        AddedProducts.Add(product.Id);
        StateHasChanged();
    }
}