@page "/cart"
@layout CartLayout
@using Shop.Common
@using Shop.Entities
@using ShopWASM
@inject CartService CartService
@inject NavigationManager Nav
@implements IDisposable

<div class="cart-page">
    <div class="cart-header">
        <button class="back-btn" @onclick='() => Nav.NavigateTo("/")'>← Назад</button>
        <h2 class="cart-title">Корзина</h2>
    </div>

    @if (!CartService.Items.Any())
    {
        <div class="cart-empty">
            <span>🛒</span>
            <p>Корзина пуста</p>
        </div>
    }
    else
    {
        <div class="cart-items">
            @foreach (var item in CartService.Items)
            {
                <div class="cart-item">
                    <img src="@item.Product.ImageSource" alt="@item.Product.Name" class="cart-item-img" />
                    <div class="cart-item-info">
                        <span class="cart-item-name">@item.Product.Name</span>
                        <span class="cart-item-price">@item.Product.Price €</span>
                    </div>
                    <div class="cart-item-qty">
                        <button class="qty-btn" @onclick="() => CartService.DecreaseQuantity(item.Product.Id)">−</button>
                        <span class="qty-value">@item.Quantity</span>
                        <button class="qty-btn" @onclick="() => CartService.Add(item.Product)">+</button>
                    </div>
                    <span class="cart-item-total">@item.Total €</span>
                    <button class="remove-btn" @onclick="() => CartService.Remove(item.Product.Id)">✕</button>
                </div>
            }
        </div>

        <div class="cart-footer">
            <span class="cart-total-label">Итого:</span>
            <span class="cart-total-value">@CartService.TotalPrice €</span>
        </div>
    }
</div>

<style>
    .cart-page {
        background: #1a0505;
        min-height: 100vh;
        padding: 2rem;
        color: #f0e6d3;
    }

    .cart-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .back-btn {
        background: transparent;
        border: 1px solid rgba(180,60,60,0.4);
        color: #a06060;
        padding: 0.4rem 1rem;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .back-btn:hover {
            border-color: #b43c3c;
            color: #f0e6d3;
        }

    .cart-title {
        font-size: 1.6rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        margin: 0;
    }

    .cart-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        margin-top: 5rem;
        opacity: 0.4;
        font-size: 1.1rem;
    }

        .cart-empty span {
            font-size: 3rem;
        }

    .cart-items {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .cart-item {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        background: #2a0a0a;
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 4px;
        padding: 0.8rem 1.2rem;
        transition: border-color 0.2s;
    }

        .cart-item:hover {
            border-color: rgba(180,60,60,0.4);
        }

    .cart-item-img {
        width: 64px;
        height: 64px;
        object-fit: cover;
        border-radius: 3px;
        flex-shrink: 0;
    }

    .cart-item-info {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .cart-item-name {
        font-size: 0.95rem;
        font-weight: 500;
    }

    .cart-item-price {
        font-size: 0.85rem;
        color: #a06060;
    }

    .cart-item-qty {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .qty-btn {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: 1px solid rgba(180,60,60,0.5);
        background: transparent;
        color: #a06060;
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

        .qty-btn:hover {
            background: rgba(180,60,60,0.2);
            color: #f0e6d3;
        }

    .qty-value {
        min-width: 20px;
        text-align: center;
        font-size: 0.95rem;
    }

    .cart-item-total {
        min-width: 70px;
        text-align: right;
        color: #f0e6d3;
        font-size: 0.95rem;
    }

    .remove-btn {
        background: transparent;
        border: none;
        color: rgba(180,60,60,0.5);
        font-size: 1rem;
        cursor: pointer;
        padding: 0.3rem 0.5rem;
        transition: color 0.2s;
    }

        .remove-btn:hover {
            color: #b43c3c;
        }

    .cart-footer {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 1.5rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.08);
        font-size: 1.2rem;
    }

    .cart-total-label {
        color: #a06060;
    }

    .cart-total-value {
        font-weight: 600;
        letter-spacing: 0.05em;
    }
</style>

@code {
    protected override void OnInitialized()
    {
        CartService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        CartService.OnChange -= StateHasChanged;
    }
}